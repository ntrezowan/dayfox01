      "omnibox_background_hovered":[212, 202, 187],
      "omnibox_selected_keyword_background": [212, 202, 187]
    },

    "tints": {
      "buttons":           [0.08, 0.45, 0.38],
      "frame":             [-1,  -1,   -1],
      "frame_inactive":    [-1,  -1,   1.05],
      "frame_incognito":   [-1,  -1,   -1],
      "background_tab":    [-1,  -1,   1.08]
    },

    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat":    "no-repeat",
      "ntp_logo_alternate":       0
    }
